<Window x:Class="DBTeam.App.Shell.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource About.Title}" Height="360" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ui:WindowHelper.UseModernWindowStyle="True">
    <DockPanel Margin="24">
        <Border DockPanel.Dock="Bottom" Padding="0,12,0,0">
            <Button HorizontalAlignment="Right" Width="100" IsCancel="True" Click="Close_Click" Style="{StaticResource PrimaryButton}">
                <TextBlock Text="{DynamicResource About.Close}"/>
            </Button>
        </Border>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <md:PackIcon Kind="DatabaseCheck" Width="56" Height="56" Foreground="{StaticResource Brand.Primary}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DB TEAM" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource About.Version}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
            <TextBlock Text="{DynamicResource About.Description}" TextWrapping="Wrap" Margin="0,0,0,12"/>
            <Border Style="{StaticResource Divider}"/>
            <TextBlock Text="Stack" FontWeight="SemiBold" Margin="0,8,0,4"/>
            <TextBlock Text="WPF · .NET 8 · AvalonDock · AvalonEdit · ModernWpfUI · MaterialDesign · Microsoft.Data.SqlClient · ScriptDom · Bogus" TextWrapping="Wrap" Opacity="0.75"/>
        </StackPanel>
    </DockPanel>
</Window>
