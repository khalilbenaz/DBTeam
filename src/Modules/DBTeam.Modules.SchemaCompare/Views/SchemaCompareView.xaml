<UserControl x:Class="DBTeam.Modules.SchemaCompare.Views.SchemaCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="Compare" Width="28" Height="28" VerticalAlignment="Center" Foreground="{StaticResource Brand.Primary}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Welcome.SchemaCompare}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{DynamicResource Welcome.SchemaCompareDesc}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Padding="16,12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <md:PackIcon Kind="SourceBranch" VerticalAlignment="Center" Foreground="{StaticResource Brand.Source}" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Label.Source}" FontWeight="SemiBold" Foreground="{StaticResource Brand.Source}"/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Connections}" DisplayMemberPath="Name" SelectedItem="{Binding SourceConnection}" Margin="0,2"/>
                    <ComboBox ItemsSource="{Binding SourceDatabases}" SelectedItem="{Binding SourceDatabase}" IsEditable="True" Margin="0,2"/>
                </StackPanel>
                <md:PackIcon Grid.Column="1" Kind="ArrowRightBold" Width="28" Height="28" VerticalAlignment="Center" Margin="8,20,8,0" Opacity="0.5"/>
                <StackPanel Grid.Column="2" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <md:PackIcon Kind="Target" VerticalAlignment="Center" Foreground="{StaticResource Brand.Target}" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Label.Target}" FontWeight="SemiBold" Foreground="{StaticResource Brand.Target}"/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Connections}" DisplayMemberPath="Name" SelectedItem="{Binding TargetConnection}" Margin="0,2"/>
                    <ComboBox ItemsSource="{Binding TargetDatabases}" SelectedItem="{Binding TargetDatabase}" IsEditable="True" Margin="0,2"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="16,0,0,0">
                    <Button Command="{Binding CompareCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Compare" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Btn.Compare}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding GenerateScriptCommand}" Style="{StaticResource SuccessButton}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ScriptTextPlay" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Btn.SyncScript}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <md:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6"/>
            <StatusBarItem><TextBlock Text="{Binding Status}"/></StatusBarItem>
        </StatusBar>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Label.Differences}" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                    <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <md:PackIcon Width="16" Height="16" Margin="6,0" VerticalAlignment="Center">
                                            <md:PackIcon.Style>
                                                <Style TargetType="md:PackIcon">
                                                    <Setter Property="Kind" Value="CircleOutline"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="OnlyInSource">
                                                            <Setter Property="Kind" Value="PlusCircle"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Brand.Success}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="OnlyInTarget">
                                                            <Setter Property="Kind" Value="MinusCircle"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Brand.Danger}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Different">
                                                            <Setter Property="Kind" Value="NotEqualVariant"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Brand.Warning}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Identical">
                                                            <Setter Property="Kind" Value="CheckCircle"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Brand.Muted}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </md:PackIcon.Style>
                                        </md:PackIcon>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Kind" Binding="{Binding KindLabel}" Width="120"/>
                            <DataGridTextColumn Header="Object" Binding="{Binding QualifiedName}" Width="*"/>
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="SourceBranch" Foreground="{StaticResource Brand.Source}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource Label.SourceScript}" FontWeight="SemiBold" Foreground="{StaticResource Brand.Source}"/>
                            </StackPanel>
                        </Border>
                        <TextBox Text="{Binding Selected.SourceScript, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True" TextWrapping="NoWrap"/>
                    </DockPanel>
                </Border>
                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent"/>
                <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Target" Foreground="{StaticResource Brand.Target}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource Label.TargetScript}" FontWeight="SemiBold" Foreground="{StaticResource Brand.Target}"/>
                            </StackPanel>
                        </Border>
                        <TextBox Text="{Binding Selected.TargetScript, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True" TextWrapping="NoWrap"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
