<UserControl x:Class="DBTeam.Modules.Documenter.Views.DocumenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="FileDocument" Width="28" Height="28" VerticalAlignment="Center" Foreground="{StaticResource Brand.Primary}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Doc.Title}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{DynamicResource Doc.Subtitle}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <md:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6"/>
            <StatusBarItem><TextBlock Text="{Binding Status}"/></StatusBarItem>
        </StatusBar>

        <StackPanel Margin="24" MaxWidth="700" HorizontalAlignment="Center">
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Doc.Target}" Style="{StaticResource H2}"/>
                    <TextBlock Text="{DynamicResource Designer.Connection}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Connections}" DisplayMemberPath="Name" SelectedItem="{Binding Connection}" Margin="0,0,0,12"/>
                    <TextBlock Text="{DynamicResource Designer.Database}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Databases}" SelectedItem="{Binding Database}" IsEditable="True"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Doc.Output}" Style="{StaticResource H2}"/>
                    <TextBlock Text="{Binding LastOutput}" TextWrapping="Wrap" Opacity="0.8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Command="{Binding GenerateCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="FileDocumentArrowRight" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource Doc.GenerateOpen}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenLastCommand}" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="OpenInNew" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource Doc.OpenLast}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </DockPanel>
</UserControl>
