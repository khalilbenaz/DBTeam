<UserControl x:Class="DBTeam.Modules.Terminal.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="Console" Width="28" Height="28" VerticalAlignment="Center" Foreground="{StaticResource Brand.Primary}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Terminal.Title}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{DynamicResource Terminal.Subtitle}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Padding="16,12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Terminal.Shell}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding ShellChoices}" Text="{Binding Shell}" IsEditable="True"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Terminal.WorkDir}" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding StartCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0" ToolTip="Start shell">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Play" Margin="0,0,6,0"/><TextBlock Text="{DynamicResource Terminal.Start}"/></StackPanel>
                    </Button>
                    <Button Command="{Binding StopCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Terminal.Stop}" IsEnabled="{Binding IsRunning}">
                        <md:PackIcon Kind="Stop" Foreground="{StaticResource Brand.Danger}"/>
                    </Button>
                    <Button Command="{Binding ClearCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Terminal.Clear}">
                        <md:PackIcon Kind="Broom"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <md:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6"/>
            <StatusBarItem><TextBlock Text="{Binding Status}"/></StatusBarItem>
        </StatusBar>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" x:Name="OutputBox" Text="{Binding Output, Mode=OneWay}" IsReadOnly="True"
                         FontFamily="Cascadia Code, Consolas" FontSize="12"
                         Background="#0B1021" Foreground="#E2E8F0"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         AcceptsReturn="True" TextWrapping="NoWrap"
                         TextChanged="Output_TextChanged"/>
                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&gt;" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource Brand.Success}"/>
                    <TextBox Grid.Column="1" x:Name="InputBox" Text="{Binding CurrentInput, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Code, Consolas" KeyDown="InputBox_KeyDown"/>
                    <Button Grid.Column="2" Command="{Binding SendCommand}" Style="{StaticResource PrimaryButton}" Margin="6,0,0,0" ToolTip="Send (Enter)">
                        <md:PackIcon Kind="Send"/>
                    </Button>
                </Grid>
            </Grid>
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0" Margin="8,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Terminal.Snippets}" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                    <ListBox ItemsSource="{Binding QuickSnippets}" Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" Background="Transparent" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.UseSnippetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
