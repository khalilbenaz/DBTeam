<UserControl x:Class="DBTeam.Modules.QueryBuilder.Views.QueryBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:DBTeam.Modules.QueryBuilder.ViewModels">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="TableLarge" Width="28" Height="28" VerticalAlignment="Center" Foreground="{StaticResource Brand.Primary}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Qb.Title}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{DynamicResource Qb.Subtitle}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Padding="16,12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Qb.Connection}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Connections}" DisplayMemberPath="Name" SelectedItem="{Binding Connection}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Qb.Database}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Databases}" SelectedItem="{Binding Database}" IsEditable="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding BuildCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Wrench" Margin="0,0,6,0"/><TextBlock Text="{DynamicResource Qb.Build}"/></StackPanel>
                    </Button>
                    <Button Command="{Binding OpenInEditorCommand}" Style="{StaticResource SuccessButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="OpenInNew" Margin="0,0,6,0"/><TextBlock Text="{DynamicResource Qb.OpenInEditor}"/></StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <md:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6"/>
            <StatusBarItem><TextBlock Text="{Binding Status}"/></StatusBarItem>
        </StatusBar>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Tables &amp; Views" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                    <TreeView ItemsSource="{Binding Tables}" Background="Transparent">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="False"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type vm:TablePickVm}" ItemsSource="{Binding Columns}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,4,0"/>
                                    <md:PackIcon Kind="Table" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{StaticResource Brand.Primary}"/>
                                    <TextBlock Text="{Binding QualifiedName}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ColumnPickVm}">
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Name}" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding DataType}" Opacity="0.6" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox Content="{DynamicResource Qb.Distinct}" IsChecked="{Binding Distinct}" Margin="0,0,12,0"/>
                            <TextBlock Text="TOP" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Text="{Binding TopN, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" Width="60"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource Qb.Where}" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding WhereClause, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" Margin="0,0,0,6"/>
                        <TextBlock Text="{DynamicResource Qb.OrderBy}" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding OrderBy, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,8,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Qb.GeneratedSql}" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                        <TextBox Text="{Binding GeneratedSql, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True" TextWrapping="NoWrap"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
