<UserControl x:Class="DBTeam.Modules.Profiler.Views.ProfilerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="ChartLine" Width="28" Height="28" VerticalAlignment="Center" Foreground="{StaticResource Brand.Primary}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Profiler.Title}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{DynamicResource Profiler.Subtitle}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Padding="16,12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Designer.Connection}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Connections}" DisplayMemberPath="Name" SelectedItem="{Binding Connection}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Designer.Database}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Databases}" SelectedItem="{Binding Database}" IsEditable="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding EstimatedCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="SitemapOutline" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Profiler.Estimated}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ActualCommand}" Style="{StaticResource SuccessButton}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Play" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Profiler.ActualPlan}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <md:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6"/>
            <StatusBarItem><TextBlock Text="{Binding Status}"/></StatusBarItem>
        </StatusBar>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="1.3*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="T-SQL" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                    <ae:TextEditor x:Name="Editor" FontFamily="Consolas" FontSize="13" ShowLineNumbers="True" SyntaxHighlighting="TSQL"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <TabControl Grid.Row="2">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="TableLarge" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Profiler.Operators}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <DataGrid ItemsSource="{Binding Operators}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Node}" Width="50"/>
                            <DataGridTextColumn Header="Operator" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Cost" Binding="{Binding EstimatedCost, StringFormat=F4}" Width="100"/>
                            <DataGridTextColumn Header="Est. rows" Binding="{Binding EstimatedRows, StringFormat=F0}" Width="100"/>
                            <DataGridTextColumn Header="Actual rows" Binding="{Binding ActualRows, StringFormat=F0}" Width="110"/>
                            <DataGridTextColumn Header="Logical reads" Binding="{Binding LogicalReads, StringFormat=F0}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="CodeTags" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Profiler.PlanXml}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <TextBox Text="{Binding PlanXml, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="NoWrap"/>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</UserControl>
