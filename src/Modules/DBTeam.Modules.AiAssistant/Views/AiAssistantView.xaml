<UserControl x:Class="DBTeam.Modules.AiAssistant.Views.AiAssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="RobotOutline" Width="28" Height="28" VerticalAlignment="Center" Foreground="{StaticResource Brand.Primary}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Ai.Title}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{DynamicResource Ai.Subtitle}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <md:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6"/>
            <StatusBarItem><TextBlock Text="{Binding Status}"/></StatusBarItem>
        </StatusBar>

        <TabControl>
            <TabItem>
                <TabItem.Header><StackPanel Orientation="Horizontal"><md:PackIcon Kind="ChatProcessingOutline" Margin="0,0,6,0"/><TextBlock Text="{DynamicResource Ai.Chat}"/></StackPanel></TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Turns}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4" Padding="12" CornerRadius="8" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <md:PackIcon Kind="{Binding Avatar}" Width="18" Height="18" Margin="0,0,6,0" Foreground="{StaticResource Brand.Primary}"/>
                                                    <TextBlock Text="{Binding Role}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <TextBox Text="{Binding Content, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                                                         BorderThickness="0" Background="Transparent"
                                                         TextWrapping="Wrap" AcceptsReturn="True"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding CurrentInput, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="60" MaxHeight="160" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas"/>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <Button Command="{Binding SendCommand}" Style="{StaticResource PrimaryButton}">
                                    <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Send" Margin="0,0,6,0"/><TextBlock Text="{DynamicResource Ai.Send}"/></StackPanel>
                                </Button>
                                <Button Command="{Binding ClearCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Ai.Clear}" Margin="0,4,0,0">
                                    <md:PackIcon Kind="Broom"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,8,8,8" Padding="0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Ai.QuickPrompts}" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                            <ListBox ItemsSource="{Binding QuickPrompts}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.UseQuickPromptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header><StackPanel Orientation="Horizontal"><md:PackIcon Kind="Cog" Margin="0,0,6,0"/><TextBlock Text="{DynamicResource Ai.Settings}"/></StackPanel></TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" MaxWidth="720" HorizontalAlignment="Left">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Ai.Preset}" Style="{StaticResource H2}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Margin="0,0,8,0" Command="{Binding UseProviderPresetCommand}" CommandParameter="Anthropic">Anthropic</Button>
                                    <Button Margin="0,0,8,0" Command="{Binding UseProviderPresetCommand}" CommandParameter="OpenAI">OpenAI</Button>
                                    <Button Margin="0,0,8,0" Command="{Binding UseProviderPresetCommand}" CommandParameter="Ollama">Ollama (local)</Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Ai.Provider}" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding ProviderChoices}" SelectedItem="{Binding Settings.Provider}" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Ai.Endpoint}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Settings.Endpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Ai.Model}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Settings.Model, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Ai.ApiKey}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Settings.ApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Ai.MaxTokens}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Settings.MaxTokens, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Ai.SystemPrompt}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Settings.SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80"/>
                                <Button Command="{Binding SaveSettingsCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Margin="0,16,0,0">
                                    <StackPanel Orientation="Horizontal"><md:PackIcon Kind="ContentSave" Margin="0,0,6,0"/><TextBlock Text="{DynamicResource Ai.Save}"/></StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
</UserControl>
