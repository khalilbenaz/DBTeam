<Window x:Class="DBTeam.Modules.ConnectionManager.Views.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:DBTeam.Modules.ConnectionManager.Converters"
        Title="{DynamicResource Dialog.ConnectionTitle}" Height="600" Width="560"
        WindowStartupLocation="CenterOwner"
        ui:WindowHelper.UseModernWindowStyle="True">
    <Window.Resources>
        <conv:AuthModeDisplayConverter x:Key="AuthModeDisplay"/>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="DatabasePlus" Width="32" Height="32" VerticalAlignment="Center" Foreground="{StaticResource Brand.Primary}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Dialog.ConnectionTitle}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{DynamicResource Dialog.ConnectionSubtitle}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource SectionHeader}" BorderThickness="0,1,0,0">
            <DockPanel>
                <md:PackIcon DockPanel.Dock="Left" Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource Brand.Muted}"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Margin="4,0" Command="{Binding TestCommand}" ToolTip="Test connection" Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="CheckNetwork" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Btn.Test}"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="4,0" Command="{Binding SaveAndConnectCommand}" IsDefault="True" Style="{StaticResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="LanConnect" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Btn.Connect}"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="4,0" Command="{Binding CancelCommand}" IsCancel="True" Padding="14,8">
                        <TextBlock Text="{DynamicResource Btn.Cancel}"/>
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Dialog.General}" Style="{StaticResource H2}"/>
                        <TextBlock Text="{DynamicResource Dialog.ConnectionName}" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Model.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        <TextBlock Text="{DynamicResource Dialog.Server}" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Model.Server, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        <TextBlock Text="{DynamicResource Dialog.Database}" Style="{StaticResource FieldLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" IsEditable="True" ItemsSource="{Binding Databases}" Text="{Binding Model.Database, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding LoadDatabasesCommand}" ToolTip="Load databases" Style="{StaticResource IconButton}">
                                <md:PackIcon Kind="Refresh" Width="18" Height="18"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Dialog.Authentication}" Style="{StaticResource H2}"/>
                        <TextBlock Text="{DynamicResource Dialog.AuthMode}" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AuthModes}" SelectedItem="{Binding Model.AuthMode}" Margin="0,0,0,12">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource AuthModeDisplay}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{DynamicResource Dialog.Login}" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Model.User, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                        <TextBlock Text="{DynamicResource Dialog.Password}" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="PwdBox" PasswordChanged="PwdBox_PasswordChanged"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Dialog.Options}" Style="{StaticResource H2}"/>
                        <CheckBox Content="{DynamicResource Dialog.TrustCert}" IsChecked="{Binding Model.TrustServerCertificate}" Margin="0,4"/>
                        <CheckBox Content="{DynamicResource Dialog.Encrypt}" IsChecked="{Binding Model.Encrypt}" Margin="0,4"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
