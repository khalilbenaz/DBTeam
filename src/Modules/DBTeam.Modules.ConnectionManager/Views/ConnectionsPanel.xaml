<UserControl x:Class="DBTeam.Modules.ConnectionManager.Views.ConnectionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Style="{StaticResource IconButton}" Command="{Binding ReloadCommand}" ToolTip="Reload">
                        <md:PackIcon Kind="Refresh" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ConnectCommand}" CommandParameter="{Binding Selected}" ToolTip="Connect">
                        <md:PackIcon Kind="LanConnect" Width="18" Height="18" Foreground="{StaticResource Brand.Success}"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding DeleteCommand}" CommandParameter="{Binding Selected}" ToolTip="Delete">
                        <md:PackIcon Kind="Delete" Width="18" Height="18" Foreground="{StaticResource Brand.Danger}"/>
                    </Button>
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Panel.Connections}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Connections.Count, StringFormat='{}{0} saved'}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <ListBox x:Name="ConnectionsList" ItemsSource="{Binding Connections}" SelectedItem="{Binding Selected}"
                     Background="Transparent" BorderThickness="0" Padding="8"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="ConnectionsList_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" CornerRadius="6" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Database" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource Brand.Primary}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="Server" Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,3,0" Opacity="0.6"/>
                                        <TextBlock Text="{Binding Server}" FontSize="11" Opacity="0.75"/>
                                        <TextBlock Text=" · " FontSize="11" Opacity="0.5"/>
                                        <TextBlock Text="{Binding Database}" FontSize="11" Opacity="0.75"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Connections.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <md:PackIcon Kind="DatabaseOff" Width="48" Height="48" HorizontalAlignment="Center" Opacity="0.4"/>
                <TextBlock Text="{DynamicResource Panel.NoConnections}" HorizontalAlignment="Center" Opacity="0.7" Margin="0,8,0,0"/>
                <TextBlock Text="{DynamicResource Panel.NoConnectionsHint}" Style="{StaticResource Caption}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
