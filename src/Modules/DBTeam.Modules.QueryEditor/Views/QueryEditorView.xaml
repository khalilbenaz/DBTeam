<UserControl x:Class="DBTeam.Modules.QueryEditor.Views.QueryEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding ExecuteCommand}" Style="{StaticResource SuccessButton}" ToolTip="{DynamicResource Tip.Execute}" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Play" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Btn.Execute}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding EstimatedPlanCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Qe.EstimatedPlan}">
                    <md:PackIcon Kind="SitemapOutline" Width="20" Height="20"/>
                </Button>
                <Button Command="{Binding FormatSqlCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Qe.FormatSql}">
                    <md:PackIcon Kind="FormatAlignLeft" Width="20" Height="20"/>
                </Button>
                <Button Command="{Binding GeneratePivotCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Qe.Pivot}">
                    <md:PackIcon Kind="TableHeadersEye" Width="20" Height="20"/>
                </Button>
                <Menu Background="Transparent" Margin="0">
                    <MenuItem ToolTip="{DynamicResource Qe.ExportResults}">
                        <MenuItem.Header>
                            <md:PackIcon Kind="FileExport" Width="20" Height="20"/>
                        </MenuItem.Header>
                        <MenuItem Header="{DynamicResource Qe.ExportCsv}" Command="{Binding ExportCommand}" CommandParameter="Csv">
                            <MenuItem.Icon><md:PackIcon Kind="FileDelimited"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Qe.ExportExcel}" Command="{Binding ExportCommand}" CommandParameter="Excel">
                            <MenuItem.Icon><md:PackIcon Kind="MicrosoftExcel" Foreground="#217346"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Qe.ExportJson}" Command="{Binding ExportCommand}" CommandParameter="Json">
                            <MenuItem.Icon><md:PackIcon Kind="CodeJson"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Qe.ExportXml}" Command="{Binding ExportCommand}" CommandParameter="Xml">
                            <MenuItem.Icon><md:PackIcon Kind="CodeBraces"/></MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                </Menu>
                <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="8,4"/>
                <md:PackIcon Kind="Database" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6"/>
                <ComboBox Width="200" Margin="0,0,4,0" ItemsSource="{Binding Databases}" SelectedItem="{Binding Database}" ToolTip="{DynamicResource Qe.DbContext}"/>
                <Button Command="{Binding RefreshDatabasesCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Qe.RefreshDb}" Margin="0,0,12,0">
                    <md:PackIcon Kind="Refresh" Width="14" Height="14"/>
                </Button>
                <Border Style="{StaticResource Pill}" Background="{StaticResource Brand.Info}">
                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <md:PackIcon Kind="Timer" Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,3,0" Opacity="0.6"/>
                    <TextBlock Text="{Binding Elapsed, StringFormat='\{0:mm\\:ss\\.fff\}'}" FontSize="12" Opacity="0.8"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <md:PackIcon Kind="TableRow" Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,3,0" Opacity="0.6"/>
                    <TextBlock Text="{Binding RowCount, StringFormat='{}{0} rows'}" FontSize="12" Opacity="0.8"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderThickness="0" Padding="0">
                <ae:TextEditor x:Name="Editor"
                               FontFamily="Consolas" FontSize="13"
                               ShowLineNumbers="True"
                               SyntaxHighlighting="TSQL"
                               WordWrap="False"/>
            </Border>

            <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" Background="Transparent"/>

            <TabControl Grid.Row="2">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="TableLarge" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Label.Results}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="6,4" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Qe.Zoom}" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7"/>
                                <Button Command="{Binding ZoomOutCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Qe.ZoomOut}" Padding="4">
                                    <md:PackIcon Kind="MagnifyMinus" Width="14" Height="14"/>
                                </Button>
                                <TextBlock Text="{Binding ZoomFactor, StringFormat={}{0:P0}}" VerticalAlignment="Center" Margin="4,0" MinWidth="40" TextAlignment="Center"/>
                                <Button Command="{Binding ZoomInCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Qe.ZoomIn}" Padding="4">
                                    <md:PackIcon Kind="MagnifyPlus" Width="14" Height="14"/>
                                </Button>
                                <Button Command="{Binding ZoomResetCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Qe.ZoomReset}" Padding="4" Margin="0,0,12,0">
                                    <md:PackIcon Kind="Restore" Width="14" Height="14"/>
                                </Button>
                                <TextBlock Text="{DynamicResource Qe.Timeout}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding CommandTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Width="60" VerticalAlignment="Center" ToolTip="{DynamicResource Qe.TimeoutTip}"/>
                                <TextBlock Text="s" VerticalAlignment="Center" Margin="2,0,0,0" Opacity="0.6"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Results}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DataGrid ItemsSource="{Binding}" AutoGenerateColumns="True" IsReadOnly="True" Margin="0,0,0,8"
                                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                                  MaxHeight="500" ColumnWidth="SizeToHeader"
                                                  EnableRowVirtualization="True" EnableColumnVirtualization="True">
                                            <DataGrid.LayoutTransform>
                                                <ScaleTransform ScaleX="{Binding DataContext.ZoomFactor, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                ScaleY="{Binding DataContext.ZoomFactor, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            </DataGrid.LayoutTransform>
                                        </DataGrid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="MessageTextOutline" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Label.Messages}"/>
                        </StackPanel>
                    </TabItem.Header>
                    <TextBox Text="{Binding Messages}" IsReadOnly="True"
                             FontFamily="Consolas" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True" TextWrapping="NoWrap"/>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</UserControl>
