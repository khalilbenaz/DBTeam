<UserControl x:Class="DBTeam.Modules.QueryEditor.Views.QueryHistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="History" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.8"/>
                    <TextBlock Text="Query History" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ReloadCommand}" ToolTip="Reload" Margin="8,0,0,0">
                        <md:PackIcon Kind="Refresh" Width="14" Height="14"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ClearCommand}" ToolTip="Clear history">
                        <md:PackIcon Kind="DeleteSweep" Width="14" Height="14" Foreground="{StaticResource Brand.Danger}"/>
                    </Button>
                </StackPanel>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" md:HintAssist.Hint="Filter..."/>
                    <ToggleButton Grid.Column="1" IsChecked="{Binding FavoritesOnly}" Margin="6,0,0,0" ToolTip="Favorites only" Padding="6">
                        <md:PackIcon Kind="Star" Width="16" Height="16" Foreground="#FFC107"/>
                    </ToggleButton>
                </Grid>
            </StackPanel>
        </Border>

        <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" Background="Transparent" BorderThickness="0"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,1"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenInNewTabCommand}" CommandParameter="{Binding Selected}"/>
            </ListBox.InputBindings>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" CornerRadius="4">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon VerticalAlignment="Center" Margin="0,0,6,0" Width="14" Height="14">
                                    <md:PackIcon.Style>
                                        <Style TargetType="md:PackIcon">
                                            <Setter Property="Kind" Value="CheckCircle"/>
                                            <Setter Property="Foreground" Value="{StaticResource Brand.Success}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Success}" Value="False">
                                                    <Setter Property="Kind" Value="AlertCircle"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Brand.Danger}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </md:PackIcon.Style>
                                </md:PackIcon>
                                <TextBlock Text="{Binding Preview}" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                                <md:PackIcon Kind="Star" Width="12" Height="12" Foreground="#FFC107" Margin="6,0,0,0"
                                             Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="20,2,0,0">
                                <TextBlock Text="{Binding ExecutedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" FontSize="10" Opacity="0.6"/>
                                <TextBlock Text=" · " FontSize="10" Opacity="0.5"/>
                                <TextBlock Text="{Binding ConnectionName}" FontSize="10" Opacity="0.7"/>
                                <TextBlock Text=" · " FontSize="10" Opacity="0.5"/>
                                <TextBlock Text="{Binding Database}" FontSize="10" Opacity="0.7"/>
                                <TextBlock Text="{Binding Elapsed, StringFormat=' · {0:mm\\:ss\\.fff}'}" FontSize="10" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.Resources>
                <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            </ListBox.Resources>
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open in new tab" Command="{Binding OpenInNewTabCommand}" CommandParameter="{Binding Selected}">
                        <MenuItem.Icon><md:PackIcon Kind="FileDocumentPlus"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Toggle favorite" Command="{Binding ToggleFavoriteCommand}" CommandParameter="{Binding Selected}">
                        <MenuItem.Icon><md:PackIcon Kind="Star" Foreground="#FFC107"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding Selected}">
                        <MenuItem.Icon><md:PackIcon Kind="Delete" Foreground="{StaticResource Brand.Danger}"/></MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>
    </DockPanel>
</UserControl>
