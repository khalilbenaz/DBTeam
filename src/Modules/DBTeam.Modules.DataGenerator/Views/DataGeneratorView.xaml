<UserControl x:Class="DBTeam.Modules.DataGenerator.Views.DataGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="DatabaseSync" Width="28" Height="28" VerticalAlignment="Center" Foreground="{StaticResource Brand.Primary}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Gen.Title}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{DynamicResource Gen.Subtitle}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Padding="16,12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Designer.Connection}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Connections}" DisplayMemberPath="Name" SelectedItem="{Binding Connection}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Designer.Database}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Databases}" SelectedItem="{Binding Database}" IsEditable="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Label.Table}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedTable}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,8,0" Width="100">
                    <TextBlock Text="{DynamicResource Gen.Rows}" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding RowCount, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                    <CheckBox Content="{DynamicResource Gen.SkipIdentity}" IsChecked="{Binding SkipIdentity}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding PreviewCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Eye" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Gen.Preview}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportScriptCommand}" Margin="0,0,8,0" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="ScriptTextPlay" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Gen.ExportScript}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding InsertCommand}" Style="{StaticResource SuccessButton}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="DatabasePlus" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource Gen.Insert}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <md:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6"/>
            <StatusBarItem><TextBlock Text="{Binding Status}"/></StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <ProgressBar Width="200" Minimum="0" Maximum="{Binding RowCount}" Value="{Binding ProgressValue}"/>
            </StatusBarItem>
        </StatusBar>

        <Border Margin="8" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Gen.Preview}" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                <DataGrid ItemsSource="{Binding PreviewTable}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
