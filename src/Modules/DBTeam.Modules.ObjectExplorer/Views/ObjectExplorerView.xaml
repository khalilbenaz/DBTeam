<UserControl x:Class="DBTeam.Modules.ObjectExplorer.Views.ObjectExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:DBTeam.Modules.ObjectExplorer.ViewModels"
             xmlns:conv="clr-namespace:DBTeam.Modules.ObjectExplorer.Converters">
    <UserControl.Resources>
        <conv:KindToIconConverter x:Key="KindToIcon"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="{Binding Kind, Converter={StaticResource KindToIcon}}" VerticalAlignment="Center" Margin="0,0,4,0" Width="16" Height="16"/>
                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                <md:PackIcon Kind="Loading" Width="14" Height="14" VerticalAlignment="Center" Margin="6,0,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="FileTree" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7"/>
                <TextBlock Text="{Binding Roots.Count, StringFormat='{}{0} connection(s)'}" VerticalAlignment="Center" Opacity="0.8"/>
            </StackPanel>
        </Border>
    <TreeView x:Name="Tree" ItemsSource="{Binding Roots}" Background="Transparent" SelectedItemChanged="Tree_SelectedItemChanged">
        <TreeView.ItemContainerStyle>
            <Style TargetType="TreeViewItem">
                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            </Style>
        </TreeView.ItemContainerStyle>
        <TreeView.InputBindings>
            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenNewQueryCommand}" CommandParameter="{Binding Selected}"/>
        </TreeView.InputBindings>
        <TreeView.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{DynamicResource Ctx.NewQueryHere}" Command="{Binding OpenNewQueryCommand}" CommandParameter="{Binding Selected}">
                    <MenuItem.Icon><md:PackIcon Kind="FileDocumentPlus"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource Ctx.ScriptObject}" Command="{Binding ScriptObjectCommand}" CommandParameter="{Binding Selected}">
                    <MenuItem.Icon><md:PackIcon Kind="CodeBraces"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource Ctx.Disconnect}" Command="{Binding DisconnectServerCommand}" CommandParameter="{Binding Selected}">
                    <MenuItem.Icon><md:PackIcon Kind="LanDisconnect" Foreground="#C62828"/></MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </TreeView.ContextMenu>
    </TreeView>
    </DockPanel>
</UserControl>
