<UserControl x:Class="DBTeam.Modules.Debugger.Views.DebuggerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="Bug" Width="28" Height="28" VerticalAlignment="Center" Foreground="{StaticResource Brand.Primary}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Debugger.Title}" Style="{StaticResource H1}"/>
                    <TextBlock Text="{DynamicResource Debugger.Subtitle}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Padding="16,12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Debugger.Connection}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Connections}" DisplayMemberPath="Name" SelectedItem="{Binding Connection}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="{DynamicResource Debugger.Database}" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Databases}" SelectedItem="{Binding Database}" IsEditable="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding AttachCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0" ToolTip="Parse script + open connection">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="DebugStart" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Debugger.Attach}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding StepOverCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Debugger.StepOver}"
                            IsEnabled="{Binding IsAttached}">
                        <md:PackIcon Kind="DebugStepOver"/>
                    </Button>
                    <Button Command="{Binding StepIntoCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Debugger.StepInto}"
                            IsEnabled="{Binding IsAttached}">
                        <md:PackIcon Kind="DebugStepInto"/>
                    </Button>
                    <Button Command="{Binding ContinueCommand}" Style="{StaticResource SuccessButton}" Margin="6,0,0,0"
                            IsEnabled="{Binding IsAttached}" ToolTip="Continue until next breakpoint or end">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Play" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource Debugger.Continue}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding StopCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Debugger.Stop}" Margin="6,0,0,0"
                            IsEnabled="{Binding IsRunning}">
                        <md:PackIcon Kind="Stop" Foreground="{StaticResource Brand.Danger}"/>
                    </Button>
                    <Button Command="{Binding RestartCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Debugger.Restart}"
                            IsEnabled="{Binding IsAttached}">
                        <md:PackIcon Kind="Restart"/>
                    </Button>
                    <Button Command="{Binding DetachCommand}" Style="{StaticResource IconButton}" ToolTip="{DynamicResource Debugger.Detach}"
                            IsEnabled="{Binding IsAttached}">
                        <md:PackIcon Kind="DebugStepOut"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <md:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6"/>
            <StatusBarItem><TextBlock Text="{Binding Status}"/></StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock Text="{Binding Breakpoints.Count, StringFormat='{}{0} breakpoint(s)'}" Opacity="0.7"/></StatusBarItem>
        </StatusBar>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Debugger.Script}" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                        <ae:TextEditor x:Name="Editor" FontFamily="Consolas" FontSize="13" ShowLineNumbers="True" SyntaxHighlighting="TSQL"/>
                    </DockPanel>
                </Border>
                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent"/>
                <TabControl Grid.Row="2">
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="TableLarge" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource Debugger.Results}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <ItemsControl ItemsSource="{Binding Results}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DataGrid ItemsSource="{Binding}" AutoGenerateColumns="True" IsReadOnly="True" Margin="0,0,0,8"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="MessageTextOutline" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource Debugger.Messages}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <TextBox Text="{Binding Messages}" IsReadOnly="True" FontFamily="Consolas" BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True" TextWrapping="NoWrap"/>
                    </TabItem>
                </TabControl>
            </Grid>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Debugger.Steps}" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                        <ListBox ItemsSource="{Binding Steps}" SelectedItem="{Binding CurrentStep}" Background="Transparent" BorderThickness="0"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ToggleBreakpointCommand}" CommandParameter="{Binding CurrentStep}"/>
                            </ListBox.InputBindings>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" CornerRadius="4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="●" Foreground="{StaticResource Brand.Danger}" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Index, StringFormat='#{0}'}" FontFamily="Consolas" FontSize="11" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding StartLine, StringFormat='L{0}'}" FontFamily="Consolas" FontSize="11" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Kind}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource Brand.Primary}"/>
                                            <TextBlock Text="{Binding Preview}" FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource Debugger.ToggleBreakpoint}" Command="{Binding ToggleBreakpointCommand}" CommandParameter="{Binding CurrentStep}">
                                        <MenuItem.Icon><md:PackIcon Kind="CircleOutline" Foreground="{StaticResource Brand.Danger}"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource Debugger.SetCondition}" Command="{Binding SetBreakpointConditionCommand}" CommandParameter="{Binding CurrentStep}">
                                        <MenuItem.Icon><md:PackIcon Kind="CodeBraces" Foreground="{StaticResource Brand.Primary}"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{DynamicResource Debugger.ClearCondition}" Command="{Binding ClearBreakpointConditionCommand}" CommandParameter="{Binding CurrentStep}">
                                        <MenuItem.Icon><md:PackIcon Kind="CloseCircleOutline"/></MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent"/>

                <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Debugger.SessionState}" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                        <DataGrid ItemsSource="{Binding SessionInfo}" AutoGenerateColumns="True" IsReadOnly="True"
                                  HeadersVisibility="Column" CanUserSortColumns="False"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
