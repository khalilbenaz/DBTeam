<UserControl x:Class="DBTeam.Modules.Import.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource SectionHeader}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="FileImportOutline" Width="28" Height="28" VerticalAlignment="Center" Foreground="{StaticResource Brand.Primary}" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Import CSV" Style="{StaticResource H1}"/>
                    <TextBlock Text="Pick a file · preview + auto type inference · bulk insert" Style="{StaticResource Caption}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Padding="16,12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,6">
                    <TextBlock Text="Connection" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Connections}" DisplayMemberPath="Name" SelectedItem="{Binding Connection}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,6">
                    <TextBlock Text="Database" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Databases}" SelectedItem="{Binding Database}" IsEditable="True"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,6">
                    <TextBlock Text="Schema" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Schema, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,8,6">
                    <TextBlock Text="Table" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding TableName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding PickFileCommand}" Style="{StaticResource IconButton}" ToolTip="Pick file">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="FolderOpen" Margin="0,0,6,0"/><TextBlock Text="Browse"/></StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,4,0,0">
                    <CheckBox Content="Has header" IsChecked="{Binding HasHeader}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Delimiter:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding Delimiter, UpdateSourceTrigger=PropertyChanged}" Width="40" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding FilePath}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Opacity="0.7"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding LoadPreviewCommand}" Style="{StaticResource IconButton}" ToolTip="Reload preview">
                        <md:PackIcon Kind="Refresh"/>
                    </Button>
                    <Button Command="{Binding GenerateCreateScriptCommand}" Style="{StaticResource IconButton}" ToolTip="Generate CREATE TABLE script">
                        <md:PackIcon Kind="ScriptTextPlay"/>
                    </Button>
                    <Button Command="{Binding ImportCommand}" Style="{StaticResource SuccessButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="DatabasePlus" Margin="0,0,6,0"/><TextBlock Text="Import"/></StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <md:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6"/>
            <StatusBarItem><TextBlock Text="{Binding Status}"/></StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock Text="{Binding RowCount, StringFormat='{}{0} row(s)'}"/></StatusBarItem>
        </StatusBar>

        <Border Margin="8" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Preview" Style="{StaticResource H2}" Margin="12,8,12,4"/>
                <DataGrid ItemsSource="{Binding Preview}" AutoGenerateColumns="True" IsReadOnly="True"/>
            </DockPanel>
        </Border>
    </DockPanel>
</UserControl>
